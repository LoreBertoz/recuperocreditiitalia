# === Database (PostgreSQL) ===
# Locale (dev): postgres://<utente>@127.0.0.1:5432/recuperocrediti
# Produzione (Supabase): postgresql://postgres:<PASSWORD>@db.<PROJECT_REF>.supabase.co:5432/postgres
DATABASE_URL=postgres://user@127.0.0.1:5432/recuperocrediti

# === Payload CMS ===
# Chiave segreta per auth/sessioni. Genera con: openssl rand -hex 32
PAYLOAD_SECRET=CAMBIAMI_CON_UNA_CHIAVE_CASUALE

# === Sito ===
# URL pubblico del sito (usato per metadata, canonical, sitemap)
NEXT_PUBLIC_SITE_URL=http://localhost:3000

# === Analytics (Fase 3 — opzionali in dev) ===
# ID misurazione Google Analytics 4 (es. G-XXXXXXXXXX)
NEXT_PUBLIC_GA_MEASUREMENT_ID=

# === Stripe (predisposto, NON attivo — pagamenti manuali) ===
STRIPE_SECRET_KEY=
STRIPE_WEBHOOK_SECRET=
NEXT_PUBLIC_STRIPE_PUBLISHABLE_KEY=
